
# ── Google OAuth ──────────────────────────────────────────────────────────────
# Crea credenciales en: https://console.cloud.google.com
#   APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   Desarrollo  → Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#   Producción  → Authorized redirect URIs: 
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth Secret ───────────────────────────────────────────────────────────
# Genera uno con: openssl rand -base64 32
AUTH_SECRET=

# ── URL del cliente ───────────────────────────────────────────────────────────
# Desarrollo:  http://localhost:9002
# Producción:  
CLIENT_ORIGIN=


# ── Pexels ──────────────────────────────────────────────────
# 1. Ve a https://www.pexels.com/api/
# 2. Crea cuenta gratuita → "Get Started" → copia la API key
# Límite gratuito: 200 req/hora, 20.000/mes
PEXELS_API_KEY=

# ── Google Genkit ─────────────────────────────────────────────────────────────
# Obtenlo en: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=

# ── Prisma / Base de datos de recetas ─────────────────────────────────────────
# SQLite en desarrollo (no requiere instalación)
# Para PostgreSQL en producción: 
DATABASE_URL="file:./data/recipes.db"